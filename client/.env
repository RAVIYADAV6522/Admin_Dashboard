# API base URL (no trailing slash) — must match your Express server
VITE_BASE_URL=http://localhost:9000

# When true (default), unauthenticated users are redirected to /login
VITE_REQUIRE_AUTH=true

# Used only when VITE_REQUIRE_AUTH=false — MongoDB user _id for layout/API calls without login
# VITE_DEFAULT_USER_ID=63701cc1f03239b7f700000e
