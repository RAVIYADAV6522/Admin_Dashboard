MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
PORT=9000

# CORS: must match the Vite dev server origin (default http://localhost:3000)
CLIENT_URL=http://localhost:3000

# JWT — required when AUTH_ENABLED is not false
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Set to false to allow API access without a Bearer token (local development only)
AUTH_ENABLED=true

# Optional: max requests per IP per 15 minutes (global middleware)
RATE_LIMIT_MAX=300
